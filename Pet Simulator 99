        TweenService:Create(glow, TweenInfo.new(0.32), {Transparency=0.4, Enabled=true}):Play()

        local p = TweenService:Create(glow, TweenInfo.new(2.1, Enum.EasingStyle.Sine, Enum.EasingDirection.InOut, -1, true), {Transparency=0.22})
        p:Play()
        tabButtons[name].pulse = p

        activeTabLabel.Text = "Active Tab: " .. name
        rebuildContent()
    end)

