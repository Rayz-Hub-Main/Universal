    btn.TextSize = 15
    btn.AutoButtonColor = false
    btn.Parent = sidebar

    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,8)

    local left = Instance.new("Frame", btn)
    left.Size = UDim2.new(0,0,1,0)
    left.Position = UDim2.new(0,-2,0,0)
    left.BackgroundColor3 = Color3.fromRGB(200,110,255)
    left.BorderSizePixel = 0
    Instance.new("UICorner", left).CornerRadius = UDim.new(1,0)

    local glow = Instance.new("UIStroke", btn)
    glow.Color = Color3.fromRGB(210,130,255)
    glow.Thickness = 2.5
    glow.Transparency = 0.7
    glow.Enabled = false

    Instance.new("UIGradient", glow).Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(255,220,255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(140,80,255))
    }

    tabButtons[name] = {btn=btn, left=left, glow=glow, pulse=nil}

    btn.MouseEnter:Connect(function()
        if isMinimized or selectedTab == name then return end
        pcall(function() hoverSound:Play() end)
        TweenService:Create(btn, TweenInfo.new(0.2), {BackgroundColor3=Color3.fromRGB(55,40,95), Size=UDim2.new(1,-6,0,44)}):Play()
        TweenService:Create(glow, TweenInfo.new(0.2), {Transparency=0.35, Enabled=true}):Play()
    end)

    btn.MouseLeave:Connect(function()
        if isMinimized or selectedTab == name then return end
        TweenService:Create(btn, TweenInfo.new(0.24), {BackgroundColor3=Color3.fromRGB(35,25,60), Size=UDim2.new(1,-12,0,42)}):Play()
        TweenService:Create(glow, TweenInfo.new(0.24), {Transparency=0.7}):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        if isMinimized or selectedTab == name then return end
        pcall(function() clickSound:Play() end)

        local old = tabButtons[selectedTab]
        if old then
            TweenService:Create(old.btn, TweenInfo.new(0.32, Enum.EasingStyle.Quint), {BackgroundColor3=Color3.fromRGB(35,25,60), TextColor3=Color3.fromRGB(200,160,255)}):Play()
            TweenService:Create(old.left, TweenInfo.new(0.28, Enum.EasingStyle.Back), {Size=UDim2.new(0,0,1,0)}):Play()
            TweenService:Create(old.glow, TweenInfo.new(0.32), {Transparency=0.7}):Play()
            if old.pulse then old.pulse:Cancel() end
        end

        selectedTab = name

        TweenService:Create(btn, TweenInfo.new(0.32, Enum.EasingStyle.Quint), {BackgroundColor3=Color3.fromRGB(70,50,115), TextColor3=Color3.fromRGB(240,210,255)}):Play()
